# Ricknad client-side environment variables.
#
# Secrets are configured in Vercel (Project Settings → Environment Variables).
# This file documents the variable NAMES only — never commit real values.
#
# WARNING: Vite inlines every VITE_* variable into the public JS bundle.
# Only put values here that are safe to expose to browsers (public RPC URLs,
# rate-limited public API keys, public builder codes).

# BaseScan / Etherscan V2 API key.
# Used for wallet analytics and BaseScan contract verification on Base Mainnet.
# Create / upgrade a key at: https://basescan.org/myapikey
VITE_BASESCAN_API_KEY=your_basescan_api_key_here

# Base "Builder Code" — opaque identifier appended to every transaction's
# calldata so Base attributes activity to this app.
VITE_BASE_BUILDER_CODE=your_base_builder_code_here

# Optional: explicit hex suffix appended to every transaction's `data` field.
# Defaults to VITE_BASE_BUILDER_CODE when unset.
VITE_BASE_DATA_SUFFIX=
